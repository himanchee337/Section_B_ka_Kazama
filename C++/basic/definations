#include<iostream>
using namespace std;
void swap(int *a, int *b){

    int t=*a;
     *a=*b;
    *b=t;


}
int main(){
    int a=5,b=20;
    cout<<"values before swap : "<<a<<" "<<b<<endl;
    swap(&a,&b);
    cout<<"values after swap : "<<a<<" "<<b<<endl;
    return 0;

}